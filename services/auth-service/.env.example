NODE_ENV=development
PORT=3001

# Must match gateway JWT_SECRET — used for signing and verifying access tokens
JWT_SECRET=your-jwt-secret-minimum-32-characters!!!!!
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-characters!
JWT_ACCESS_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800

# Must match the value in gateway and user-service
INTERNAL_SECRET=your-internal-secret-min-32-characters!!

# PostgreSQL — auth_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auth_db
