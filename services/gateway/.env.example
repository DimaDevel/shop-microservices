NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Must match the value in auth-service and user-service
INTERNAL_SECRET=your-internal-secret-min-32-characters!!

# Used to verify access tokens issued by auth-service
JWT_SECRET=your-jwt-secret-minimum-32-characters!!!!!

# Downstream service URLs (use docker-compose hostnames in Docker, localhost for local dev)
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002

REQUEST_TIMEOUT_MS=5000
