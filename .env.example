# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET=replace-with-a-random-secret-minimum-32-chars
JWT_REFRESH_SECRET=replace-with-another-random-secret-min-32-chars

# Token lifetimes in seconds (access: 1h, refresh: 7d)
JWT_ACCESS_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800

# ── Internal service-to-service auth ─────────────────────────────────────────
# Sent by the gateway in x-internal-secret header; must match across all services
INTERNAL_SECRET=replace-with-internal-secret-minimum-32-chars

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_PASSWORD=postgres
