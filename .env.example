# JWT
JWT_SECRET=replace-with-a-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-another-random-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800

# Internal service-to-service secret
INTERNAL_SECRET=replace-with-internal-secret-min-32-chars

# PostgreSQL
DB_PASSWORD=postgres
